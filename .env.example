# PULSE City environment variables (sample)
#
# The MVP runs fully on mock / simulated city data and needs NO API keys.
# This file documents optional variables for future integrations.
# Copy to ".env" (which is git-ignored) and fill in if/when you add them.
#
# All client-exposed Vite variables MUST be prefixed with VITE_.

# Optional: a weather feed for live storm probability (future improvement)
VITE_WEATHER_API_KEY=

# Optional: a map / geocoding provider (future improvement)
VITE_MAP_API_KEY=
